<Window x:Class="SecurityProgram.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SecurityProgram.App.ViewModels"
        xmlns:view="clr-namespace:SecurityProgram.App.Views"
        Title="Security Program"
        Width="1100"
        Height="700"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:EncryptionViewModel}">
            <view:EncryptionView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EventLogViewModel}">
            <view:EventLogView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PasswordViewModel}">
            <view:PasswordView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NetworkViewModel}">
            <view:NetworkView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportViewModel}">
            <view:ReportView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1E1E2D">
            <StackPanel>
                <TextBlock Text="Security Program"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="20,30,20,30" />

                <Button Content="File Encryption"
                        Command="{Binding ShowEncryptionCommand}"
                        Height="45"
                        Margin="10"
                        Foreground="White" />

                <Button Content="Event Log"
                        Command="{Binding ShowEventLogCommand}"
                        Height="45"
                        Margin="10"
                        Foreground="White" />

                <Button Content="Password Check"
                        Command="{Binding ShowPasswordCommand}"
                        Height="45"
                        Margin="10"
                        Foreground="White" />

                <Button Content="Network"
                        Command="{Binding ShowNetworkCommand}"
                        Height="45"
                        Margin="10"
                        Foreground="White" />

                <Button Content="Report"
                        Command="{Binding ShowReportCommand}"
                        Height="45"
                        Margin="10"
                        Foreground="White" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="#F5F5F7"
                Padding="20">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>
    </Grid>
</Window>
