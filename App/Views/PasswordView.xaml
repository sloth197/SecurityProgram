<UserControl x:Class="SecurityProgram.App.Views.PasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:SecurityProgram.App.Behaviors">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="비밀번호 보안 분석기"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,12" />

        <Border Grid.Row="1"
                Background="White"
                Padding="16"
                CornerRadius="8"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <PasswordBox Grid.Column="0"
                             Height="34"
                             VerticalContentAlignment="Center"
                             behaviors:PasswordBoxHelper.BoundPassword="{Binding PasswordInput, Mode=TwoWay}" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="12,0,0,0">
                    <Button Content="생성"
                            Width="90"
                            Margin="0,0,8,0"
                            Command="{Binding GenerateSamplePasswordCommand}" />
                    <Button Content="복사"
                            Width="75"
                            Margin="0,0,8,0"
                            Command="{Binding CopyCurrentPasswordCommand}" />
                    <Button Content="초기화"
                            Width="75"
                            Command="{Binding ClearCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <ProgressBar Minimum="0"
                             Maximum="100"
                             Height="18"
                             Value="{Binding PasswordScore, Mode=OneWay}" />
                <TextBlock Margin="0,6,0,0"
                           FontWeight="SemiBold"
                           Text="{Binding PasswordLevelKorean, StringFormat=강도: {0}}" />
                <TextBlock Foreground="DimGray"
                           Text="{Binding EstimatedEntropyBits, StringFormat=추정 엔트로피: {0:F1} 비트}" />
            </StackPanel>

            <TextBox Grid.Column="1"
                     IsReadOnly="True"
                     Background="#F8F8FA"
                     Text="{Binding GeneratedPassword, Mode=OneWay}"
                     ToolTip="최근 생성된 샘플 비밀번호"
                     VerticalContentAlignment="Center" />
        </Grid>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="8"
                    Padding="14"
                    Margin="0,0,0,10">
                <ItemsControl ItemsSource="{Binding RuleChecklist}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,3,0,3"
                                       FontSize="13"
                                       Text="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <TextBlock Grid.Row="1"
                       TextWrapping="Wrap"
                       Foreground="DarkSlateGray"
                       Text="{Binding FeedbackMessage}" />
        </Grid>
    </Grid>
</UserControl>
