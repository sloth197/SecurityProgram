<UserControl x:Class="SecurityProgram.App.Views.EncryptionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:SecurityProgram.App.Behaviors">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="File Encryption / Decryption"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,15" />

        <Border Grid.Row="1"
                Background="White"
                Padding="20"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="Selected file"
                           FontWeight="SemiBold" />
                <DockPanel Margin="0,5,0,15">
                    <TextBox Text="{Binding SelectedFilePath}"
                             IsReadOnly="True"
                             Height="32"
                             VerticalContentAlignment="Center" />
                    <Button Content="Browse"
                            Width="80"
                            Margin="10,0,0,0"
                            Command="{Binding BrowseFileCommand}" />
                </DockPanel>

                <TextBlock Text="Password"
                           FontWeight="SemiBold" />
                <PasswordBox Height="32"
                             Margin="0,5,0,10"
                             behaviors:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <ProgressBar Minimum="0"
                             Maximum="100"
                             Height="18"
                             Value="{Binding PasswordScore, Mode=OneWay}"
                             Margin="0,5,0,5" />
                <TextBlock Text="{Binding PasswordLevel}"
                           FontWeight="SemiBold"
                           Foreground="DarkGray"
                           Margin="0,0,0,6" />
                <TextBlock Text="{Binding InputHint}"
                           Foreground="DimGray"
                           Margin="0,0,0,15"
                           TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Content="Encrypt"
                            Width="120"
                            Height="40"
                            Margin="0,0,10,0"
                            IsEnabled="{Binding CanEncrypt}"
                            Command="{Binding EncryptCommand}" />

                    <Button Content="Decrypt"
                            Width="120"
                            Height="40"
                            IsEnabled="{Binding CanDecrypt}"
                            Command="{Binding DecryptCommand}" />
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="Gray"
                           Margin="0,20,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

